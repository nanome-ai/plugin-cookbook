   "source": [
    "import websocket\n",
    "import os\n",
    "import json\n",
    "ws_url = os.environ.get(\"WEBSOCKET_SERVER\")\n",
    "print(ws_url)\n",
    "ws = websocket.WebSocket()\n",
    "ws.connect(ws_url)\n",
    "ws.send(json.dumps({\"type\":\"host\", \"data\":\"World\"}))\n",
    "print(ws.recv())\n",
    "ws.close()"
   ]
  },
